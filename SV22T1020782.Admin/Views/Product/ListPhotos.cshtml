@model List<SV22T1020782.Models.Catalog.ProductPhoto>
@{
    Layout = null;
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="photos" class="mb-0">
                            <i class="bi bi-images me-2"></i> Thư viện ảnh
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="~/Product/CreatePhoto/@ViewContext.RouteData.Values["id"]">
                            <i class="bi bi-plus-circle me-1"></i> Thêm ảnh
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:120px" class="text-center">Ảnh</th>
                            <th>Mô tả</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:120px" class="text-center">Trạng thái</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                         class="img-thumbnail"
                                         style="max-height:80px;" />
                                </td>
                                <td class="align-middle">@item.Description</td>
                                <td class="text-center align-middle">@item.DisplayOrder</td>
                                <td class="text-center align-middle">
                                    @if (item.IsHidden)
                                    {
                                        <span class="badge bg-secondary">Đã ẩn</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Hiển thị</span>
                                    }
                                </td>
                                <td class="text-center text-nowrap align-middle">
                                    <a class="btn btn-sm btn-primary" href="~/Product/EditPhoto/@item.ProductID?photoId=@item.PhotoID">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-danger"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deletePhotoModal"
                                            onclick="document.getElementById('btnConfirmDeletePhoto').href = '@Url.Action("DeletePhoto", "Product", new { id = item.ProductID, photoId = item.PhotoID })';">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deletePhotoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i> Xác nhận xóa ảnh</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-start fs-6 text-dark">
                Bạn có chắc chắn muốn xóa bức ảnh này khỏi thư viện không? Hành động này không thể hoàn tác.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                <a id="btnConfirmDeletePhoto" href="#" class="btn btn-danger">Xác nhận xóa</a>
            </div>
        </div>
    </div>
</div>