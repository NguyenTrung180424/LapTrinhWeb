@model ProductSearchInput

@{
    ViewBag.Title = "Quản lý Mặt hàng";
}

@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">

        <form id="formSearch"
              method="get"
              action="~/Product/Search"
              data-target="searchResult">

            <input type="hidden" asp-for="PageSize" />

            <div class="row g-2">

                <div class="col-md-3">
                    <label class="form-label">Loại hàng</label>
                    <select class="form-select" asp-for="CategoryID" asp-items="await SelectListHelper.Categories()">
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Nhà cung cấp</label>
                    <select class="form-select" asp-for="SupplierID" asp-items="await SelectListHelper.Suppliers()">
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>

                    <div class="input-group">
                        <input asp-for="MinPrice"
                               class="form-control money-input"
                               placeholder="Từ" />

                        <span class="input-group-text">-</span>

                        <input asp-for="MaxPrice"
                               class="form-control money-input"
                               placeholder="Đến" />
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Tên mặt hàng</label>

                    <div class="input-group">
                        <input asp-for="SearchValue"
                               class="form-control"
                               placeholder="Tên mặt hàng..." autofocus />

                        <button class="btn btn-info">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>

            </div>
        </form>

    </div>
</div>

<div id="searchResult"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
        });
            // ==============================
        // Format số tiền có dấu . hàng nghìn
        // ==============================

        function formatNumber(value) {
            // bỏ ký tự không phải số
            value = value.replace(/\D/g, "");

            // thêm dấu . phân cách nghìn
            return value.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
        }

        document.querySelectorAll(".money-input").forEach(input => {

            input.addEventListener("input", function () {

                let cursorPosition = this.selectionStart;
                let originalLength = this.value.length;

                this.value = formatNumber(this.value);

                let newLength = this.value.length;
                cursorPosition += newLength - originalLength;

                this.setSelectionRange(cursorPosition, cursorPosition);
            });

        });

        // ==============================
        // Khi submit form -> Xóa chấm -> Gửi AJAX -> Phục hồi chấm
        // ==============================

        document.getElementById("formSearch").addEventListener("submit", function (e) {
            e.preventDefault(); // Chặn hành vi tải lại trang mặc định

            let moneyInputs = document.querySelectorAll(".money-input");

            // 1. Tạm thời xóa dấu chấm để gửi số nguyên chuẩn về CSDL
            moneyInputs.forEach(input => {
                input.dataset.displayValue = input.value; // Lưu tạm cái chuỗi đẹp (có dấu chấm) lại
                input.value = input.value.replace(/\./g, ""); // Xóa chấm đi
            });

            // 2. Gọi hàm gửi AJAX
            paginationSearch(null, this, 1);

            // 3. Trả lại dấu chấm cho giao diện ngay lập tức (Khách hàng sẽ không hề hay biết)
            moneyInputs.forEach(input => {
                input.value = input.dataset.displayValue;
            });
        });

    </script>
}