@{
    ViewData["Title"] = "Trang chủ";
}

<div id="shopBanner" class="carousel slide mb-4 shadow-sm rounded overflow-hidden" data-bs-ride="carousel" data-bs-interval="3000">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#shopBanner" data-bs-slide-to="0" class="active" aria-current="true"></button>
        <button type="button" data-bs-target="#shopBanner" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#shopBanner" data-bs-slide-to="2"></button>
        <button type="button" data-bs-target="#shopBanner" data-bs-slide-to="3"></button>
        <button type="button" data-bs-target="#shopBanner" data-bs-slide-to="4"></button>
    </div>

    <div class="carousel-inner" style="max-height: 400px;">
        <div class="carousel-item active">
            <img src="~/images/banner/pic1.jpg" class="d-block w-100" alt="" style="object-fit: cover;">
        </div>
        <div class="carousel-item">
            <img src="~/images/banner/pic2.jpg" class="d-block w-100" alt="" style="object-fit: cover;">
        </div>
        <div class="carousel-item">
            <img src="~/images/banner/pic3.jpg" class="d-block w-100" alt="" style="object-fit: cover;">
        </div>
        <div class="carousel-item">
            <img src="~/images/banner/pic4.jpg" class="d-block w-100" alt="" style="object-fit: cover;">
        </div>
        <div class="carousel-item">
            <img src="~/images/banner/pic5.jpg" class="d-block w-100" alt="" style="object-fit: cover;">
        </div>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#shopBanner" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#shopBanner" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
    </button>
</div>

<div class="mb-5 text-center">
    <h3 class="fw-bold mb-4">KHÁM PHÁ DANH MỤC</h3>
    <div class="d-flex justify-content-center flex-wrap gap-3">
        <a href="~/Product?reset=true" class="btn btn-outline-primary rounded-pill px-4 fw-medium fs-5">
            Tất cả sản phẩm
        </a>

        @if (ViewBag.Categories != null)
        {
            foreach (var cat in ViewBag.Categories)
            {
                <a href="~/Product?categoryId=@cat.CategoryID" class="btn btn-outline-primary rounded-pill px-4 fw-medium fs-5">
                    @cat.CategoryName
                </a>
            }
        }
    </div>
</div>

<div class="row text-center mt-5 mb-4">
    <div class="col-md-3 mb-4">
        <i class="bi bi-truck text-primary mb-3 d-block" style="font-size: 3rem;"></i>
        <h5 class="fw-bold">Giao hàng siêu tốc</h5>
        <p class="text-muted small">Miễn phí giao hàng cho đơn từ 500k toàn quốc.</p>
    </div>
    <div class="col-md-3 mb-4">
        <i class="bi bi-shield-check text-success mb-3 d-block" style="font-size: 3rem;"></i>
        <h5 class="fw-bold">Chất lượng đảm bảo</h5>
        <p class="text-muted small">Cam kết hàng chính hãng 100%, bảo hành uy tín.</p>
    </div>
    <div class="col-md-3 mb-4">
        <i class="bi bi-arrow-repeat text-warning mb-3 d-block" style="font-size: 3rem;"></i>
        <h5 class="fw-bold">Đổi trả dễ dàng</h5>
        <p class="text-muted small">Hỗ trợ đổi trả miễn phí trong vòng 7 ngày.</p>
    </div>
    <div class="col-md-3 mb-4">
        <i class="bi bi-headset text-info mb-3 d-block" style="font-size: 3rem;"></i>
        <h5 class="fw-bold">Hỗ trợ 24/7</h5>
        <p class="text-muted small">Luôn sẵn sàng giải đáp thắc mắc của bạn.</p>
    </div>
</div>

<div class="text-center mb-5">
    <a href="~/Product?reset=true" class="btn btn-danger btn-lg px-5 fw-bold rounded-pill shadow">
        MUA SẮM NGAY <i class="bi bi-arrow-right-circle ms-2"></i>
    </a>
</div>

