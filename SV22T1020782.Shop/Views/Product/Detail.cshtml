@model Product
@{
    ViewData["Title"] = Model.ProductName;
}

<div class="mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="~/Product" class="text-decoration-none text-primary fw-bold">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                </a>
            </li> 
            <li class="breadcrumb-item active" aria-current="page">@Model.ProductName</li>
        </ol>
    </nav>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-md-5 mb-3 text-center">
                <img src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)" class="img-fluid rounded mb-3 border p-2" alt="@Model.ProductName" style="max-height: 400px; object-fit: contain;">

                @if (ViewBag.Photos != null)
                {
                    <div class="d-flex gap-2 justify-content-center overflow-auto">
                        @foreach (var photo in ViewBag.Photos)
                        {
                            if (!photo.IsHidden)
                            {
                                <img src="~/images/products/@photo.Photo" class="img-thumbnail" style="width: 80px; height: 80px; object-fit: cover; cursor: pointer;" alt="Gallery Image">
                            }
                        }
                    </div>
                }
            </div>

            <div class="col-md-7">
                <h2 class="fw-bold mb-3">@Model.ProductName</h2>
                <div class="mb-3">
                    <span class="badge bg-secondary me-2">@Model.CategoryName</span>
                    <span class="text-muted">Nhà cung cấp: <strong>@Model.SupplierName</strong></span>
                </div>

                <h3 class="text-danger fw-bold mb-4">@Model.Price.ToString("N0") đ</h3>

                <div class="mb-4">
                    <p class="mb-1"><strong>Đơn vị tính:</strong> @Model.Unit</p>
                    <p class="mb-1"><strong>Trạng thái:</strong> @(Model.IsSelling ? "Đang kinh doanh" : "Ngừng kinh doanh")</p>
                </div>

                <div class="mb-4">
                    <p>@Model.ProductDescription</p>
                </div>

                @if (Model.IsSelling)
                {
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="input-group" style="width: 130px;">
                            <button class="btn btn-outline-secondary" type="button" onclick="decreaseQty()">-</button>
                            <input type="number" class="form-control text-center" id="buyQuantity" value="1" min="1">
                            <button class="btn btn-outline-secondary" type="button" onclick="increaseQty()">+</button>
                        </div>
                        <button class="btn btn-primary btn-lg px-4" onclick="addToCartDetail(@Model.ProductID)">
                            <i class="bi bi-cart-plus me-2"></i> Thêm vào giỏ hàng
                        </button>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning">Sản phẩm này hiện đang ngừng kinh doanh.</div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-bold">
        Thông số kỹ thuật
    </div>
    <div class="card-body p-0">
        <table class="table table-striped mb-0">
            <tbody>
                @if (ViewBag.Attributes != null)
                {
                    foreach (var attr in ViewBag.Attributes)
                    {
                        <tr>
                            <th class="w-25 ps-4">@attr.AttributeName</th>
                            <td>@attr.AttributeValue</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function increaseQty() {
            let input = document.getElementById('buyQuantity');
            input.value = parseInt(input.value) + 1;
        }
        function decreaseQty() {
            let input = document.getElementById('buyQuantity');
            if (parseInt(input.value) > 1) {
                input.value = parseInt(input.value) - 1;
            }
        }
        function addToCartDetail(productId) {
            //Kiểm tra trạng thái đăng nhập từ Server
            let isLoggedIn = '@(User.Identity?.IsAuthenticated == true)' === 'True';
            if (!isLoggedIn) {
                // Dùng cái hàm showModalAlert có sẵn của bạn cho nó xịn
                showModalAlert("Yêu cầu đăng nhập", "Bạn cần đăng nhập tài khoản để có thể thêm mặt hàng này vào giỏ!");
                return; // Dừng lại ngay lập tức
            }

            let qtyInput = document.getElementById('buyQuantity');
            let qty = parseInt(qtyInput.value);

            // Bắt lỗi nhập chữ linh tinh hoặc số <= 0
            if (isNaN(qty) || qty <= 0) {
                // Thay thế Toast/Alert bằng Popup
                showModalAlert("Lỗi nhập liệu", "Số lượng mua không hợp lệ. Vui lòng nhập số lượng lớn hơn 0!");
                qtyInput.value = 1; // Reset về 1
                return; // Dừng, không gửi xuống Backend
            }

            // Gọi lại hàm addToCart đã viết ở Index
            fetch('/Cart/Add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `productID=${productId}&quantity=${qty}`
            })
            .then(res => res.json())
            .then(data => {

                showToastNotification(data.message, data.code === 1);

                if (data.code === 1) {
                    document.querySelector('.badge.bg-danger').innerText = data.count;
                }
            });
        }
    </script>
}