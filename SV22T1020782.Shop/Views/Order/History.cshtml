@model IEnumerable<SV22T1020782.Models.Sales.OrderViewInfo>
@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<div class="card border-0 shadow-sm mt-4 mb-5">
    <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2"></i>Lịch sử mua hàng của bạn</h5>
        <a href="~/Product" class="btn btn-sm btn-light fw-bold text-primary">Tiếp tục mua sắm</a>
    </div>
    <div class="card-body p-0">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show m-3">
                <i class="bi bi-check-circle-fill me-1"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <img src="https://cdn-icons-png.flaticon.com/512/11329/11329060.png" alt="No Orders" style="width: 120px; opacity: 0.5;" class="mb-3">
                <h5 class="text-muted fw-bold">Bạn chưa có đơn hàng nào!</h5>
                <p class="text-muted">Hãy nhanh tay chọn cho mình những món đồ ưng ý nhé.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center">Mã ĐH</th>
                            <th>Ngày đặt</th>
                            <th>Nơi giao</th>
                            <th class="text-end">Tổng tiền</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center fw-bold text-secondary">#@item.OrderID</td>
                                <td>
                                    <div class="fw-medium">@item.OrderTime.ToString("dd/MM/yyyy")</div>
                                    <small class="text-muted">@item.OrderTime.ToString("HH:mm")</small>
                                </td>
                                <td>
                                    <div class="text-truncate" style="max-width: 200px;" title="@item.DeliveryAddress, @item.DeliveryProvince">
                                        @item.DeliveryAddress, @item.DeliveryProvince
                                    </div>
                                </td>
                                <td class="text-end fw-bold text-danger">@item.TotalPrice.ToString("N0") đ</td>
                                <td class="text-center">
                                    @if (item.Status == SV22T1020782.Models.Sales.OrderStatusEnum.New)
                                    {
                                        <span class="badge bg-primary rounded-pill px-3 py-2">Đơn mới</span>
                                    }
                                    else if (item.Status == SV22T1020782.Models.Sales.OrderStatusEnum.Accepted)
                                    {
                                        <span class="badge bg-info text-dark rounded-pill px-3 py-2">Đã duyệt</span>
                                    }
                                    else if (item.Status == SV22T1020782.Models.Sales.OrderStatusEnum.Shipping)
                                    {
                                        <span class="badge bg-warning text-dark rounded-pill px-3 py-2">Đang giao</span>
                                    }
                                    else if (item.Status == SV22T1020782.Models.Sales.OrderStatusEnum.Completed)
                                    {
                                        <span class="badge bg-success rounded-pill px-3 py-2">Hoàn tất</span>
                                    }
                                    else if (item.Status == SV22T1020782.Models.Sales.OrderStatusEnum.Cancelled)
                                    {
                                        <span class="badge bg-danger rounded-pill px-3 py-2">Đã hủy</span>
                                    }
                                    else if (item.Status == SV22T1020782.Models.Sales.OrderStatusEnum.Rejected)
                                    {
                                        <span class="badge bg-dark rounded-pill px-3 py-2">Bị từ chối</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a href="~/Order/Details/@item.OrderID" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i> Xem
                                    </a>
                                </td>
                            </tr>
                        }
                        
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>