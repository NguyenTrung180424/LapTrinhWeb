@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-5">
        <div class="card shadow border-0 rounded-lg">
            <div class="card-header bg-danger text-white py-3 text-center">
                <h5 class="mb-0 fw-bold"><i class="bi bi-shield-lock me-2"></i>Đổi mật khẩu</h5>
            </div>
            <div class="card-body p-4">

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show">
                        <i class="bi bi-check-circle-fill me-1"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        @Html.ValidationSummary(false, "", new { @class = "text-danger mb-0" })
                    </div>
                }

                <form action="~/Account/ChangePassword" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu hiện tại</label>
                        <input type="password" class="form-control" name="oldPassword" required autofocus>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu mới</label>
                        <input type="password" class="form-control" name="newPassword" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Xác nhận mật khẩu mới</label>
                        <input type="password" class="form-control" name="confirmPassword" required>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger"><i class="bi bi-key me-1"></i> Cập nhật mật khẩu</button>
                        <a href="~/Account/Profile" class="btn btn-outline-secondary">Trở về hồ sơ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>