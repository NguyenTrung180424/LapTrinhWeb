@model Customer
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-8">
        <div class="card shadow border-0 rounded-lg">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-person-lines-fill me-2"></i>Thông tin cá nhân</h5>
            </div>
            <div class="card-body p-4">

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show">
                        <i class="bi bi-check-circle-fill me-1"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        @Html.ValidationSummary(false, "", new { @class = "text-danger mb-0" })
                    </div>
                }

                <form action="~/Account/Profile" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Email (Tài khoản đăng nhập)</label>
                            <input type="email" class="form-control bg-light" value="@Model.Email" readonly disabled>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Họ và Tên <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="CustomerName" value="@Model.CustomerName" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Số điện thoại</label>
                            <input type="text" class="form-control" name="Phone" value="@Model.Phone">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tỉnh/Thành phố <span class="text-danger">*</span></label>
                            <select class="form-select" name="Province" required>
                                @if (ViewBag.Provinces != null)
                                {
                                    foreach (var item in ViewBag.Provinces)
                                    {
                                        if (item.Value == Model.Province)
                                        {
                                            <option value="@item.Value" selected>@item.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@item.Value">@item.Text</option>
                                        }
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-12 mb-4">
                            <label class="form-label fw-bold">Địa chỉ chi tiết</label>
                            <input type="text" class="form-control" name="Address" value="@Model.Address" placeholder="Số nhà, Tên đường, Phường/Xã...">
                        </div>
                    </div>

                    <div class="text-end border-top pt-3">
                        <a href="~/" class="btn btn-secondary me-2">Quay lại Trang chủ</a>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-floppy me-1"></i> Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>